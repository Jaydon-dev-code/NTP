            </Grid>
            <hc:Divider
                Height="1"
                Margin="1"
                HorizontalAlignment="Stretch"
                LineStroke="#CCCCCC"
                LineStrokeThickness="1" />


        </StackPanel>

        <Grid Grid.Row="1">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="Loaded">
                    <i:InvokeCommandAction Command="{Binding LoadedCommand}" CommandParameter="{Binding ElementName=SideMenu}" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150" />
                <ColumnDefinition Width="3" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!--  左侧导航栏 最终正确版  -->

            <hc:SideMenu
                x:Name="SideMenu"
                Grid.Column="0"
                Margin="5,10,0,10">

                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="SelectionChanged">
                        <i:InvokeCommandAction Command="{Binding SelectionChangedCommand}" PassEventArgsToCommand="True" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </hc:SideMenu>

            <hc:Divider
                Grid.Column="1"
                Width="1"
                Margin="1,10"
                HorizontalAlignment="Right"
                LineStroke="#DDDDDD"
                Orientation="Vertical" />



            <!--  右侧内容区域  -->
            <Border
                Grid.Column="2"
                Margin="10"
                Background="White">
                <ContentControl Content="{Binding CurrentContent}" />
            </Border>

        </Grid>

        <StackPanel
            Grid.Row="2"
            FlowDirection="RightToLeft"
            Orientation="Horizontal">
            <TextBlock Margin="10,0" Text="{Binding VersionInfo, StringFormat=版本：V{0}}" />
            <TextBlock Text="{Binding TbTime, StringFormat=当前时间：{0}}">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="Loaded">
                        <i:InvokeCommandAction Command="{Binding TimerStartCommand}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </TextBlock>

        </StackPanel>
    </Grid>
</Window>
