<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<connectionStrings>
		<!-- <add name="DefaultConnection" connectionString="DataSource=SL.MLineDataCollction.sqlite" />-->
		<add name="DefaultConnection" connectionString="PORT=5432;DATABASE=SL.MLineDataCollction;HOST=127.0.0.1;PASSWORD=123;USER ID=postgres" />
	</connectionStrings>
	<appSettings>
		<add key="IsCreateTable" value="true" />
		<add key="SoftwareName" value="" />
		<add key="ServiceUri" value="http://localhost:59088" />
	</appSettings>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="Newtonsoft.Json" publicKeyToken="30ad4fe6b2a6aeed" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-13.0.0.0" newVersion="13.0.0.0" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>